# Copy this file to .env.local for local development.
# Never commit .env.local.

AUTH_PASSWORD=change-this-local-password
SESSION_SECRET=change-this-to-a-long-random-string
SQLITE_DB_PATH=data/notebook.db

# Dedicated secret used only by the Chrome capture extension.
EXTENSION_CAPTURE_TOKEN=change-this-to-a-long-random-string

# Required only when live AI calls are enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
