{
  "manifest_version": 3,
  "name": "Idea Store Capture",
  "version": "1.0.0",
  "description": "Save selected text to a local Idea Store.",
  "permissions": ["contextMenus", "storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Idea Store capture status"
  }
}
